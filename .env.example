# ─── Meta Conversions API ────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore and will never be committed.

# Your Meta system user access token (required for CAPI)
META_ACCESS_TOKEN=your_meta_access_token_here

# Optional: override the Pixel ID hard-coded in capi.js (default: 1914070242854182)
# META_PIXEL_ID=1914070242854182

# Optional: Meta Test Events Code — remove or leave blank for production
# META_TEST_EVENT_CODE=TEST38406

# Optional: override the default HTTP port (default: 3000)
# PORT=3000
